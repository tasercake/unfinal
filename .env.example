# Phoenix
PHX_SERVER=true
SECRET_KEY_BASE=
PORT=4000

# Clerk OAuth/OIDC server-side auth
# Dashboard: https://dashboard.clerk.com/~/oauth-applications
CLERK_FRONTEND_API_URL=https://<your-clerk-frontend-api>.clerk.accounts.dev
CLERK_OAUTH_CLIENT_ID=
CLERK_OAUTH_CLIENT_SECRET=
CLERK_OAUTH_REDIRECT_URI=http://localhost:4000/auth/clerk/callback
CLERK_OAUTH_SCOPES="email profile"

# App writers
UNFINAL_WRITERS_PATH=config/local/writers.txt

# SQLite dark-launch DB path; app data still uses R2/S3 in Phase 1.
UNFINAL_DATABASE_PATH=./.data/unfinal.sqlite3

# S3-compatible document store (Cloudflare R2 uses region auto)
UNFINAL_S3_BUCKET=
UNFINAL_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
UNFINAL_S3_ACCESS_KEY_ID=
UNFINAL_S3_SECRET_ACCESS_KEY=
UNFINAL_S3_REGION=auto
